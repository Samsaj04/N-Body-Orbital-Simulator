CoordinateSystemView1.ViewFrame = CoordinateSystem;
CoordinateSystemView1.ViewTrajectory = Off;
CoordinateSystemView1.InertialFrame = Off;
CoordinateSystemView1.SetDefaultLocation = Off;
CoordinateSystemView1.SetCurrentLocation = On;
CoordinateSystemView1.CurrentEye = [ 193098440.0202801 -285573.2608586699 1522396760.475593 ];
CoordinateSystemView1.CurrentCenter = [ 72140095.72874537 128591870.7900939 4460247.637430429 ];
CoordinateSystemView1.CurrentUp = [ -0.6822225345647478 0.7219387403894748 0.1156584128237541 ];
CoordinateSystemView1.FOVy = 45;

Create OpenFramesView EarthView1;
EarthView1.ViewFrame = Earth;
EarthView1.ViewTrajectory = Off;
EarthView1.InertialFrame = Off;
EarthView1.SetDefaultLocation = Off;
EarthView1.SetCurrentLocation = Off;
EarthView1.FOVy = 45;

Create OpenFramesView MarsView1;
MarsView1.ViewFrame = Mars;
MarsView1.ViewTrajectory = Off;
MarsView1.InertialFrame = Off;
MarsView1.SetDefaultLocation = Off;
MarsView1.SetCurrentLocation = Off;
MarsView1.FOVy = 45;

Create OpenFramesView SunView1;
SunView1.ViewFrame = Sun;
SunView1.ViewTrajectory = Off;
SunView1.InertialFrame = Off;
SunView1.SetDefaultLocation = Off;
SunView1.SetCurrentLocation = Off;
SunView1.FOVy = 45;

Create OpenFramesView SCView1;
SCView1.ViewFrame = Spacecraft;
SCView1.ViewTrajectory = Off;
SCView1.InertialFrame = Off;
SCView1.SetDefaultLocation = Off;
SCView1.SetCurrentLocation = Off;
SCView1.FOVy = 45;

Create OpenFramesView CoordinateSystemView2;
CoordinateSystemView2.ViewFrame = CoordinateSystem;
CoordinateSystemView2.ViewTrajectory = Off;
CoordinateSystemView2.InertialFrame = Off;
CoordinateSystemView2.SetDefaultLocation = Off;
CoordinateSystemView2.SetCurrentLocation = On;
CoordinateSystemView2.CurrentEye = [ -23671.27523670975 -7189.626593545365 10298.47286835965 ];
CoordinateSystemView2.CurrentCenter = [ 3.274180926382542e-11 -1.364242052659392e-11 1.091393642127514e-11 ];
CoordinateSystemView2.CurrentUp = [ 0.3621354789011438 0.1298601279484495 0.923035341734135 ];
CoordinateSystemView2.FOVy = 45;

Create OpenFramesView MarsView2;
MarsView2.ViewFrame = Mars;
MarsView2.ViewTrajectory = Off;
MarsView2.InertialFrame = Off;
MarsView2.SetDefaultLocation = Off;
MarsView2.SetCurrentLocation = Off;
MarsView2.FOVy = 45;

Create OpenFramesView SCView2;
SCView2.ViewFrame = Spacecraft;
SCView2.ViewTrajectory = Off;
SCView2.InertialFrame = Off;
SCView2.SetDefaultLocation = Off;
SCView2.SetCurrentLocation = Off;
SCView2.FOVy = 45;

Create OpenFramesView OrbitView1_View;
OrbitView1_View.ViewFrame = CoordinateSystem;
OrbitView1_View.ViewTrajectory = Off;
OrbitView1_View.InertialFrame = Off;
OrbitView1_View.SetDefaultLocation = On;
OrbitView1_View.DefaultEye = [ 30000 0 0 ];
OrbitView1_View.DefaultCenter = [ 0 0 0 ];
OrbitView1_View.DefaultUp = [ 0 0 1 ];
OrbitView1_View.SetCurrentLocation = Off;
OrbitView1_View.FOVy = 45;

BeginMissionSequence;

Target DC1 {SolveMode = Solve, ExitMode = DiscardAndContinue, ShowProgressWindow = true};
   Vary DC1(ImpulsiveBurn1.Element1 = 2.6, {Perturbation = 0.0001, Lower = 0.0, Upper = 6, MaxStep = 0.5, AdditiveScaleFactor = 0.0, MultiplicativeScaleFactor = 1.0});
   Vary DC1(ImpulsiveBurn1.Element2 = 0, {Perturbation = 0.0001, Lower = -3.0, Upper = 3.0, MaxStep = 0.5, AdditiveScaleFactor = 0.0, MultiplicativeScaleFactor = 1.0});
   Vary 'Vary3' DC1(ImpulsiveBurn1.Element3 = 0, {Perturbation = 0.0001, Lower = -7, Upper = 7, MaxStep = 0.5, AdditiveScaleFactor = 0.0, MultiplicativeScaleFactor = 1.0});
   
   Maneuver ImpulsiveBurn1(Spacecraft);
   
   Propagate Propagator_sun(Spacecraft) {Spacecraft.Mars.Periapsis, Spacecraft.ElapsedDays = 350};
   
   Achieve DC1(Spacecraft.Mars_CS.BdotT = 0, {Tolerance = 0.1});
   Achieve DC1(Spacecraft.Mars_CS.BdotR = 10000, {Tolerance = 0.1});
EndTarget;  % For targeter DC1

Target DC1 {SolveMode = Solve, ExitMode = DiscardAndContinue, ShowProgressWindow = true};
   Vary DC1(ImpulsiveBurn2.Element1 = -1.5, {Perturbation = 0.0001, Lower = -4.0, Upper = 0.0, MaxStep = 0.5, AdditiveScaleFactor = 0.0, MultiplicativeScaleFactor = 1.0});
   
   Maneuver ImpulsiveBurn2(Spacecraft);
   
   Achieve DC1(Spacecraft.Mars.ECC = 0.0, {Tolerance = 0.0001});
EndTarget;  % For targeter DC1

Propagate Propagator_mars(Spacecraft) {Spacecraft.ElapsedDays = 150, OrbitColor = Yellow};
